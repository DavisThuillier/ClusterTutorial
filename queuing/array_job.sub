#!/bin/bash

#SBATCH --job-name=haiku
#SBATCH -A [ACCOUNT NAME]
#SBATCH -p free
#SBATCH --error=logs/error_%A_%a.txt
#SBATCH --output=logs/out_%A_%a.txt
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=1
#SBATCH --time=0:02:00
#SBATCH --array=1-2

dir=./selected_haikus 
file="haiku_$SLURM_ARRAY_TASK_ID.txt"

mkdir -p $dir

cat ../haikus/$file > ./selected_haikus/$file
